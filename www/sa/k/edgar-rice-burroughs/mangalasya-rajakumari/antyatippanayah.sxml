(document @uuid "CD0YDFTLNVilav07f3Q73" (meta (copyright CC0/PD. No rights reserved)(source @url "https://standardebooks.org/ebooks/edgar-rice-burroughs/a-princess-of-mars" Standard Ebooks)(title अन्त्यटिप्पणयः)(note कृत्रिमबुद्ध्या कृतं भाषान्तरं इदं))(matter @type "chapter" (title)(ol (li @id "note-1" @type "endnote" (p अहं रेडियमशब्दं प्रयुक्तवान् अस्मिन् चूर्णे वर्णयितुं, यतः पृथिव्यां सम्प्रति आविष्कृतानां तथ्यानां प्रकाशे अहं मन्ये यत् एतत् मिश्रणं यस्य रेडियमं मूलं भवति। कैप्टन् कार्टरस्य हस्तलिखिते एतत् सर्वदा हीलियमस्य लिखितभाषायां प्रयुक्तेन नाम्ना उल्लिखितं भवति, तथा च हायरोग्लिफिक्स् इति लिखितं यत् प्रतिरूपयितुं दुष्करं निरर्थकं च भवति। (a @href "chapter-13.xhtml#noteref-1" @type "backlink" ↩)))(li @id "note-2" @type "endnote" (p श्वानः। (a @href "chapter-16.xhtml#noteref-2" @type "backlink" ↩))))))